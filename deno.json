{
    "bench": {
        "include": [
            "./bench/*.ts",
            "./bench/**/*.ts"
        ]
    },
    "compilerOptions": {
        "allowUnreachableCode": false,
        "allowUnusedLabels": false,
        "exactOptionalPropertyTypes": true,
        "noErrorTruncation": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noPropertyAccessFromIndexSignature": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strict": true,
        "strictBindCallApply": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "useUnknownInCatchVariables": true
    },
    "fmt": {
        "include": [
            "./bench/*.ts",
            "./bench/**/*.ts",
            "./scripts/*.ts",
            "./scripts/**/*.ts",
            "./src/*.ts",
            "./src/**/*.ts",
            "./tests/*.ts",
            "./tests/**/*.ts"
        ],
        "indentWidth": 4,
        "lineWidth": 80,
        "proseWrap": "always",
        "semiColons": true,
        "singleQuote": true,
        "useTabs": false
    },
    "lint": {
        "include": [
            "./bench/*.ts",
            "./bench/**/*.ts",
            "./scripts/*.ts",
            "./scripts/**/*.ts",
            "./src/*.ts",
            "./src/**/*.ts",
            "./tests/*.ts",
            "./tests/**/*.ts"
        ],
        "report": "pretty",
        "rules": {
            "include": [
                "adjacent-overload-signatures",
                "ban-ts-comment",
                "ban-types",
                "ban-unknown-rule-code",
                "ban-untagged-ignore",
                "ban-unused-ignore",
                "camelcase",
                "constructor-super",
                "default-param-last",
                "eqeqeq",
                "explicit-function-return-type",
                "explicit-module-boundary-types",
                "for-direction",
                "getter-return",
                "guard-for-in",
                "no-array-constructor",
                "no-async-promise-executor",
                "no-await-in-loop",
                "no-await-in-sync-fn",
                "no-case-declarations",
                "no-class-assign",
                "no-compare-neg-zero",
                "no-cond-assign",
                "no-const-assign",
                "no-constant-condition",
                "no-control-regex",
                "no-debugger",
                "no-delete-var",
                "no-deprecated-deno-api",
                "no-dupe-args",
                "no-dupe-class-members",
                "no-dupe-else-if",
                "no-dupe-keys",
                "no-empty",
                "no-empty-character-class",
                "no-empty-enum",
                "no-empty-interface",
                "no-empty-pattern",
                "no-eval",
                "no-ex-assign",
                "no-explicit-any",
                "no-extra-boolean-cast",
                "no-extra-non-null-assertion",
                "no-fallthrough",
                "no-func-assign",
                "no-global-assign",
                "no-import-assertions",
                "no-import-assign",
                "no-inner-declarations",
                "no-invalid-regexp",
                "no-invalid-triple-slash-reference",
                "no-irregular-whitespace",
                "no-namespace",
                "no-new-symbol",
                "no-non-null-asserted-optional-chain",
                "no-non-null-assertion",
                "no-obj-calls",
                "no-prototype-builtins",
                "no-redeclare",
                "no-regex-spaces",
                "no-self-compare",
                "no-setter-return",
                "no-shadow-restricted-names",
                "no-sparse-arrays",
                "no-sync-fn-in-async-fn",
                "no-this-alias",
                "no-this-before-super",
                "no-throw-literal",
                "no-top-level-await",
                "no-undef",
                "no-unreachable",
                "no-unsafe-finally",
                "no-unsafe-negation",
                "no-unused-labels",
                "no-unused-vars",
                "no-var",
                "no-window",
                "no-window-prefix",
                "no-with",
                "prefer-as-const",
                "prefer-ascii",
                "prefer-const",
                "prefer-namespace-keyword",
                "require-await",
                "require-yield",
                "single-var-declarator",
                "use-isnan",
                "valid-typeof",
                "verbatim-module-syntax"
            ]
        }
    },
    "lock": true,
    "nodeModulesDir": "auto",
    "tasks": {
        "build": "deno run -A ./scripts/build.ts --target current",
        "build:dev": "deno run -A ./scripts/build.ts --target dev",
        "build:release": "deno run -A ./scripts/build.ts --target release",
        "build:all": "deno run -A ./scripts/build.ts --target all",
        "build:windows": "deno run -A ./scripts/build.ts --target release-win-x64 --target dev-win-x64",
        "build:windows:x64": "deno run -A ./scripts/build.ts --target release-win-x64 --target dev-win-x64",
        "build:windows:x64:release": "deno run -A ./scripts/build.ts --target release-win-x64",
        "build:windows:x64:dev": "deno run -A ./scripts/build.ts --target dev-win-x64",
        "build:linux": "deno run -A ./scripts/build.ts --target release-linux-x64 --target dev-linux-x64 --target release-linux-aarch64 --target dev-linux-aarch64",
        "build:linux:x64": "deno run -A ./scripts/build.ts --target release-linux-x64 --target dev-linux-x64",
        "build:linux:x64:release": "deno run -A ./scripts/build.ts --target release-linux-x64",
        "build:linux:x64:dev": "deno run -A ./scripts/build.ts --target dev-linux-x64",
        "build:linux:aarch64": "deno run -A ./scripts/build.ts --target release-linux-aarch64 --target dev-linux-aarch64",
        "build:linux:aarch64:release": "deno run -A ./scripts/build.ts --target release-linux-aarch64",
        "build:linux:aarch64:dev": "deno run -A ./scripts/build.ts --target dev-linux-aarch64",
        "build:macos": "deno run -A ./scripts/build.ts --target release-macos-x64 --target dev-macos-x64 --target release-macos-aarch64 --target dev-macos-aarch64",
        "build:macos:x64": "deno run -A ./scripts/build.ts --target release-macos-x64 --target dev-macos-x64",
        "build:macos:x64:release": "deno run -A ./scripts/build.ts --target release-macos-x64",
        "build:macos:x64:dev": "deno run -A ./scripts/build.ts --target dev-macos-x64",
        "build:macos:aarch64": "deno run -A ./scripts/build.ts --target release-macos-aarch64 --target dev-macos-aarch64",
        "build:macos:aarch64:release": "deno run -A ./scripts/build.ts --target release-macos-aarch64",
        "build:macos:aarch64:dev": "deno run -A ./scripts/build.ts --target dev-macos-aarch64",
        "clean": "deno run -A ./scripts/clean.ts --target current",
        "clean:dev": "deno run -A ./scripts/clean.ts --target dev",
        "clean:release": "deno run -A ./scripts/clean.ts --target release",
        "clean:all": "deno run -A ./scripts/clean.ts --target all",
        "clean:windows": "deno run -A ./scripts/clean.ts --target release-win-x64 --target dev-win-x64",
        "clean:windows:x64": "deno run -A ./scripts/clean.ts --target release-win-x64 --target dev-win-x64",
        "clean:windows:x64:release": "deno run -A ./scripts/clean.ts --target release-win-x64",
        "clean:windows:x64:dev": "deno run -A ./scripts/clean.ts --target dev-win-x64",
        "clean:linux": "deno run -A ./scripts/clean.ts --target release-linux-x64 --target dev-linux-x64 --target release-linux-aarch64 --target dev-linux-aarch64",
        "clean:linux:x64": "deno run -A ./scripts/clean.ts --target release-linux-x64 --target dev-linux-x64",
        "clean:linux:x64:release": "deno run -A ./scripts/clean.ts --target release-linux-x64",
        "clean:linux:x64:dev": "deno run -A ./scripts/clean.ts --target dev-linux-x64",
        "clean:linux:aarch64": "deno run -A ./scripts/clean.ts --target release-linux-aarch64 --target dev-linux-aarch64",
        "clean:linux:aarch64:release": "deno run -A ./scripts/clean.ts --target release-linux-aarch64",
        "clean:linux:aarch64:dev": "deno run -A ./scripts/clean.ts --target dev-linux-aarch64",
        "clean:macos": "deno run -A ./scripts/clean.ts --target release-macos-x64 --target dev-macos-x64 --target release-macos-aarch64 --target dev-macos-aarch64",
        "clean:macos:x64": "deno run -A ./scripts/clean.ts --target release-macos-x64 --target dev-macos-x64",
        "clean:macos:x64:release": "deno run -A ./scripts/clean.ts --target release-macos-x64",
        "clean:macos:x64:dev": "deno run -A ./scripts/clean.ts --target dev-macos-x64",
        "clean:macos:aarch64": "deno run -A ./scripts/clean.ts --target release-macos-aarch64 --target dev-macos-aarch64",
        "clean:macos:aarch64:release": "deno run -A ./scripts/clean.ts --target release-macos-aarch64",
        "clean:macos:aarch64:dev": "deno run -A ./scripts/clean.ts --target dev-macos-aarch64"
    },
    "test": {
        "include": [
            "./tests/*.spec.ts",
            "./tests/**/*.spec.ts"
        ]
    },
    "unstable": []
}
