{
    "bench": {
        "include": [
            "./bench/*.ts",
            "./bench/**/*.ts"
        ]
    },
    "compilerOptions": {
        "allowUnreachableCode": false,
        "allowUnusedLabels": false,
        "exactOptionalPropertyTypes": true,
        "noErrorTruncation": true,
        "noFallthroughCasesInSwitch": true,
        "noImplicitAny": true,
        "noImplicitOverride": true,
        "noImplicitReturns": true,
        "noImplicitThis": true,
        "noPropertyAccessFromIndexSignature": true,
        "noUncheckedIndexedAccess": true,
        "noUnusedLocals": true,
        "noUnusedParameters": true,
        "strict": true,
        "strictBindCallApply": true,
        "strictFunctionTypes": true,
        "strictNullChecks": true,
        "strictPropertyInitialization": true,
        "useUnknownInCatchVariables": true
    },
    "fmt": {
        "include": [
            "./bench/*.ts",
            "./bench/**/*.ts",
            "./scripts/*.ts",
            "./scripts/**/*.ts",
            "./src/*.ts",
            "./src/**/*.ts",
            "./tests/*.ts",
            "./tests/**/*.ts"
        ],
        "indentWidth": 4,
        "lineWidth": 80,
        "proseWrap": "always",
        "semiColons": true,
        "singleQuote": true,
        "useTabs": false
    },
    "lint": {
        "include": [
            "./bench/*.ts",
            "./bench/**/*.ts",
            "./scripts/*.ts",
            "./scripts/**/*.ts",
            "./src/*.ts",
            "./src/**/*.ts",
            "./tests/*.ts",
            "./tests/**/*.ts"
        ],
        "report": "pretty",
        "rules": {
            "include": [
                "adjacent-overload-signatures",
                "ban-ts-comment",
                "ban-types",
                "ban-unknown-rule-code",
                "ban-untagged-ignore",
                "ban-unused-ignore",
                "camelcase",
                "constructor-super",
                "default-param-last",
                "eqeqeq",
                "explicit-function-return-type",
                "explicit-module-boundary-types",
                "for-direction",
                "getter-return",
                "guard-for-in",
                "no-array-constructor",
                "no-async-promise-executor",
                "no-await-in-loop",
                "no-await-in-sync-fn",
                "no-case-declarations",
                "no-class-assign",
                "no-compare-neg-zero",
                "no-cond-assign",
                "no-const-assign",
                "no-constant-condition",
                "no-control-regex",
                "no-debugger",
                "no-delete-var",
                "no-deprecated-deno-api",
                "no-dupe-args",
                "no-dupe-class-members",
                "no-dupe-else-if",
                "no-dupe-keys",
                "no-empty",
                "no-empty-character-class",
                "no-empty-enum",
                "no-empty-interface",
                "no-empty-pattern",
                "no-eval",
                "no-ex-assign",
                "no-explicit-any",
                "no-extra-boolean-cast",
                "no-extra-non-null-assertion",
                "no-fallthrough",
                "no-func-assign",
                "no-global-assign",
                "no-import-assertions",
                "no-import-assign",
                "no-inner-declarations",
                "no-invalid-regexp",
                "no-invalid-triple-slash-reference",
                "no-irregular-whitespace",
                "no-namespace",
                "no-new-symbol",
                "no-non-null-asserted-optional-chain",
                "no-non-null-assertion",
                "no-obj-calls",
                "no-prototype-builtins",
                "no-redeclare",
                "no-regex-spaces",
                "no-self-compare",
                "no-setter-return",
                "no-shadow-restricted-names",
                "no-sparse-arrays",
                "no-sync-fn-in-async-fn",
                "no-this-alias",
                "no-this-before-super",
                "no-throw-literal",
                "no-top-level-await",
                "no-undef",
                "no-unreachable",
                "no-unsafe-finally",
                "no-unsafe-negation",
                "no-unused-labels",
                "no-unused-vars",
                "no-var",
                "no-window",
                "no-window-prefix",
                "no-with",
                "prefer-as-const",
                "prefer-ascii",
                "prefer-const",
                "prefer-namespace-keyword",
                "require-await",
                "require-yield",
                "single-var-declarator",
                "use-isnan",
                "valid-typeof",
                "verbatim-module-syntax"
            ]
        }
    },
    "lock": true,
    "nodeModulesDir": "auto",
    "tasks": {
        "build": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts",
        "build:dev": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --dev",
        "build:windows": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os windows",
        "build:linux": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os linux",
        "build:macos": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os macos",
        "build:dev:windows": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os windows --dev",
        "build:dev:linux": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os linux --dev",
        "build:dev:macos": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os macos --dev",
        "build:windows:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os windows --cpu x64",
        "build:linux:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os linux --cpu x64",
        "build:linux:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os linux --cpu aarch64",
        "build:macos:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os macos --cpu x64",
        "build:macos:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os macos --cpu aarch64",
        "build:dev:windows:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os windows --cpu x64 --dev",
        "build:dev:linux:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os linux --cpu x64 --dev",
        "build:dev:linux:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os linux --cpu aarch64 --dev",
        "build:dev:macos:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os macos --cpu x64 --dev",
        "build:dev:macos:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/build.ts --os macos --cpu aarch64 --dev",
        "clean": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts",
        "clean:dev": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --dev",
        "clean:windows": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os windows",
        "clean:linux": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os linux",
        "clean:macos": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os macos",
        "clean:dev:windows": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os windows --dev",
        "clean:dev:linux": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os linux --dev",
        "clean:dev:macos": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os macos --dev",
        "clean:windows:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os windows --cpu x64",
        "clean:linux:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os linux --cpu x64",
        "clean:linux:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os linux --cpu aarch64",
        "clean:macos:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os macos --cpu x64",
        "clean:macos:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os macos --cpu aarch64",
        "clean:dev:windows:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os windows --cpu x64 --dev",
        "clean:dev:linux:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os linux --cpu x64 --dev",
        "clean:dev:linux:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os linux --cpu aarch64 --dev",
        "clean:dev:macos:x64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os macos --cpu x64 --dev",
        "clean:dev:macos:aarch64": "deno run --allow-env --allow-sys --allow-read --allow-write --allow-run ./scripts/clean.ts --os macos --cpu aarch64 --dev",
        "rebuild": "deno task clean && deno task build",
        "rebuild:dev": "deno task clean:dev && deno task build:dev",
        "rebuild:windows": "deno task clean:windows && deno task build:windows",
        "rebuild:linux": "deno task clean:linux && deno task build:linux",
        "rebuild:macos": "deno task clean:macos && deno task build:macos",
        "rebuild:dev:windows": "deno task clean:dev:windows && deno task build:dev:windows",
        "rebuild:dev:linux": "deno task clean:dev:linux && deno task build:dev:linux",
        "rebuild:dev:macos": "deno task clean:dev:macos && deno task build:dev:macos",
        "rebuild:windows:x64": "deno task clean:windows:x64 && deno task build:windows:x64",
        "rebuild:linux:x64": "deno task clean:linux:x64 && deno task build:linux:x64",
        "rebuild:linux:aarch64": "deno task clean:linux:aarch64 && deno task build:linux:aarch64",
        "rebuild:macos:x64": "deno task clean:macos:x64 && deno task build:macos:x64",
        "rebuild:macos:aarch64": "deno task clean:macos:aarch64 && deno task build:macos:aarch64",
        "rebuild:dev:windows:x64": "deno task clean:dev:windows:x64 && deno task build:dev:windows:x64",
        "rebuild:dev:linux:x64": "deno task clean:dev:linux:x64 && deno task build:dev:linux:x64",
        "rebuild:dev:linux:aarch64": "deno task clean:dev:linux:aarch64 && deno task build:dev:linux:aarch64",
        "rebuild:dev:macos:x64": "deno task clean:dev:macos:x64 && deno task build:dev:macos:x64",
        "rebuild:dev:macos:aarch64": "deno task clean:dev:macos:aarch64 && deno task build:dev:macos:aarch64"
    },
    "test": {
        "include": [
            "./tests/*.spec.ts",
            "./tests/**/*.spec.ts"
        ]
    },
    "unstable": []
}
